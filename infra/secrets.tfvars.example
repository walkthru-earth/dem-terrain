# Verda credentials
verda_client_id     = ""
verda_client_secret = ""

# SSH public key for instance access
ssh_public_key = "ssh-ed25519 AAAA..."

# Instance config (defaults in variables.tf, override here if needed)
# location      = "FIN-01"
# instance_type = "CPU.360V.1440G"  # 360 vCPUs, 1440GB RAM, $2.51/h

# S3 output (passed to the instance as env vars)
s3_bucket             = "us-west-2.opendata.source.coop"
s3_prefix             = "walkthru-earth/dem-terrain"
aws_access_key_id     = ""
aws_secret_access_key = ""
aws_region            = "us-west-2"
